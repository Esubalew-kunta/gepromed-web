# Website (public frontend) — copy to .env.local and fill in.
# PUBLISHABLE/anon key ONLY. NEVER put the service_role/secret key in a
# NEXT_PUBLIC_* var — it ships to browsers.

NEXT_PUBLIC_SUPABASE_URL=https://<project>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<anon-key>

# Staff SaaS console URL (footer link). Dev = local SaaS port; Render URL in prod.
NEXT_PUBLIC_CONSOLE_URL=http://localhost:3000

# Qualiopi program generator endpoint (the console's /api/programs). Drives the
# "Télécharger le programme (PDF)" button on training detail pages. When unset,
# the button shows a "coming soon" stub instead of a dead link.
NEXT_PUBLIC_PROGRAM_API_URL=https://gepromed-ai-console.onrender.com

# Google Analytics 4 measurement ID (optional). Get it free at analytics.google.com
# (Admin > Data Streams > your web stream). Format: G-XXXXXXXXXX. When unset, no
# analytics loads at all. When set, GA only loads AFTER a visitor accepts analytics
# cookies in the consent banner (CNIL-compliant), with IP anonymization on.
NEXT_PUBLIC_GA_ID=

# Server-only (never NEXT_PUBLIC). Used by server components / route handlers.
SUPABASE_SERVICE_ROLE_KEY=<service-role-key>
